                                <property name="label">1px</property>
                                <signal name="toggled" handler="on_line0_toggled"/>
                                <signal name="realize" handler="on_line0_realize"/>
                              </object>
                              <packing>
                                <property name="expand">False</property>
                                <property name="fill">True</property>
