            <child>
              <object id="tool_airbrush" class="GtkRadioToolButton">
                <property name="visible">True</property>
                <property name="label">Airbrush</property>
                <property name="icon_name">draw-airbrush</property>
                <signal name="toggled" handler="on_tool_airbrush_toggled"/>
                <property name="group">tool-rect-select</property>
